{
  "name": "open-videocore-api",
  "version": "0.1.0",
  "description": "OSC-native media asset management REST API",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:openapi": "bash scripts/generate-openapi.sh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@osaas/client-core": "^0.24.0",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.3.2",
    "minio": "^8.0.0",
    "nano": "^10.1.4",
    "pg": "^8.12.0",
    "ulid": "^3.0.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "happy-dom": "^20.10.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}