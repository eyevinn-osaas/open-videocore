# Copy this file to .env for local development.
# On OSC, all variables are injected at runtime from the service configuration — no .env file needed.

PORT=3000

# OSC Personal Access Token — required for provisioning OSC service instances on behalf of operators.
# On OSC this is injected automatically when the service is deployed.
# Locally: get your PAT from https://app.osaas.io/settings
OSC_ACCESS_TOKEN=
