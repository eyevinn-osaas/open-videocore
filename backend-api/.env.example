# Copy this file to .env for local development.
# On OSC, all variables are injected at runtime from the service configuration — no .env file needed.

PORT=3000

# OSC Personal Access Token — required for provisioning OSC service instances on behalf of operators.
# On OSC this is injected automatically when the service is deployed.
# Locally: get your PAT from https://app.osaas.io/settings
OSC_ACCESS_TOKEN=

# --- Provisioning credentials (ADR-002, issue #30) ---
# Sensitive credentials for newly provisioned stacks are supplied here by the
# operator, NOT in the provision request body. During provisioning each value is
# registered as a per-service OSC secret and referenced via {{secrets.<name>}};
# the literal value is never sent as a createInstance field.
# The API fails fast at startup if either of these is missing.
#
# MINIO_ROOT_PASSWORD is reused as the PostgreSQL DB password and as the S3
# secret for Encore and the Encore packager (each scoped to its own service).
MINIO_ROOT_PASSWORD=
# COUCHDB_ADMIN_PASSWORD is the CouchDB admin password.
COUCHDB_ADMIN_PASSWORD=

# OSC environment used to resolve and validate caller access tokens (workspace
# identity). Defaults to "prod" if unset. See issue #20 workspace-scoped ACL.
OSC_ENVIRONMENT=prod

# --- Workspace-scoped access control (issue #20) ---
# Callers authenticate per-request with an OSC access token in the
# Authorization: Bearer <token> header. The token is resolved to an OSC tenant,
# and that tenant id becomes the workspaceId that namespaces all resources.
# No additional API key layer is configured (ADR-001, open question 2).

# --- OSC parameter store (issue #31, ADR-002) ---
# After a stack is provisioned, its non-secret connection coordinates
# (endpoints, bucket names, service list — never passwords) are written to the
# OSC parameter store (the eyevinn-app-config-svc instance) so the API can
# rediscover a named stack at runtime. GET /api/v1/provision/:name reads them
# back.
#
# PARAMETER_STORE_URL      base URL of the eyevinn-app-config-svc instance
# PARAMETER_STORE_API_KEY  API key guarding that store (captured at store setup)
# PARAMETER_STORE_NAME     human-facing store name (e.g. openvideocore) — optional
#
# When PARAMETER_STORE_URL/API_KEY are unset, provisioning still succeeds but
# skips persistence and GET /api/v1/provision/:name responds 501.
PARAMETER_STORE_URL=
PARAMETER_STORE_API_KEY=
PARAMETER_STORE_NAME=openvideocore
