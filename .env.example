# OSC Personal Access Token — get yours at https://app.osaas.io/settings
OSC_ACCESS_TOKEN=

# Parameter store (eyevinn-app-config-svc instance, created once per installation)
PARAMETER_STORE_URL=https://<tenant>-ovcconfig.eyevinn-app-config-svc.auto.prod.osaas.io
PARAMETER_STORE_API_KEY=
PARAMETER_STORE_INSTANCE_NAME=ovcconfig

# Passwords used when provisioning new stacks
MINIO_ROOT_PASSWORD=
COUCHDB_ADMIN_PASSWORD=

# Local development only — skip OSC token validation
# Set to your OSC tenant ID (visible in the JWT or from the parameter store key prefix)
# DEV_WORKSPACE_ID=

# Optional: HTTP port (default 3000)
# PORT=3000
