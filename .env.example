# OSC Personal Access Token — get yours at https://app.osaas.io/settings
OSC_ACCESS_TOKEN=

# Parameter store (eyevinn-app-config-svc instance, created once per installation).
# The instance URL is resolved from PARAMETER_STORE_INSTANCE_NAME via the OSC SDK.
PARAMETER_STORE_API_KEY=
PARAMETER_STORE_INSTANCE_NAME=ovcconfig

# Passwords used when provisioning new stacks
MINIO_ROOT_PASSWORD=
COUCHDB_ADMIN_PASSWORD=

# Optional: HTTP port (default 3000)
# PORT=3000

# Default Encore profile index used to seed the profile store on first startup /
# bootstrap. Defaults to the Eyevinn encore-test-profiles index when unset.
# ENCORE_PROFILES_URL=https://raw.githubusercontent.com/Eyevinn/encore-test-profiles/refs/heads/main/profiles.yml

# Publicly-reachable base URL of this API. When set, Encore instances spawned by
# the auto-scaler load their profiles from this API's own
# GET /api/v1/profiles/index.yml (operator-managed profiles in CouchDB). When
# unset, they fall back to ENCORE_PROFILES_URL.
# PUBLIC_BASE_URL=https://ovc.example.com
